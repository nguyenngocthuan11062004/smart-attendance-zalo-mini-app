# Zalo eKYC Verification API credentials
# Get these from https://developers.zalo.me/ → Mini App → eKYC settings
EKYC_API_KEY=your_ekyc_api_key_here
EKYC_PRIVATE_KEY=your_base64_encoded_private_key_pem_here

# Zalo App Secret (for phone number token decoding)
ZALO_APP_SECRET_KEY=your_zalo_app_secret_here
